# MorseMate — environment template.
# Copy this file to `.env` in the repo root and fill in the values, then run the
# backend (see README.md). The same .env is read by both the voice agent and the
# token server. Never commit the real .env.

# --- LiveKit Cloud (required) -------------------------------------------------
# Create a free project at https://cloud.livekit.io and copy its credentials.
# LIVEKIT_URL is the project's wss:// URL; the key/secret are under Settings > Keys.
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your_api_key
LIVEKIT_API_SECRET=your_api_secret

# --- Optional ----------------------------------------------------------------
# Port the iOS token server listens on (default 8080). If you change it, update
# AppConfig.tokenServerURL in the iOS app to match.
# TOKEN_SERVER_PORT=8080

# Set to use named/explicit agent dispatch (e.g. the Cloud Agent Console).
# Leave unset for automatic dispatch, which the iOS app relies on.
# LIVEKIT_AGENT_NAME=morse-tutor
