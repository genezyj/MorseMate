# MorseMate — environment template.
# Copy this file to `.env` in the repo root and fill in the values, then run the
# backend agent (see agent/README.md). Never commit the real .env.

# --- LiveKit Cloud (required) -------------------------------------------------
# Create a free project at https://cloud.livekit.io and copy its credentials.
# LIVEKIT_URL is the project's wss:// URL; the key/secret are under Settings > Keys.
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your_api_key
LIVEKIT_API_SECRET=your_api_secret

# --- iOS client token endpoint (optional, used in M2+) ------------------------
# The iOS app fetches a short-lived join token from a LiveKit Cloud Sandbox
# token server. Set this to your sandbox id (Cloud dashboard > Sandbox).
# LIVEKIT_SANDBOX_ID=your_sandbox_id
